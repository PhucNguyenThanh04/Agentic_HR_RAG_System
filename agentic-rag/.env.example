
RAG_API_KEY=
API_SERVER_BASE_URL=http://localhost:8000

GOOGLE_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite
LLM_TEMPERATURE=0.0
LLM_MAX_OUTPUT_TOKENS=1024
LLM_TIMEOUT=180
RAGAS_LLM_TIMEOUT=600

QDRANT_HOST=
QDRANT_PORT=
QDRANT_COLLECTION_POLICY=    # docs nội bộ công ty
QDRANT_UPSERT_BATCH_SIZE=64

REDIS_HOST=
REDIS_PORT=
REDIS_URL=


DENSE_VECTOR_NAME= "dense"
SPARSE_VECTOR_NAME= "sparse"
BGE_M3_DENSE_SIZE= 1024


EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DEVICE=cuda        

RERANKER_MODEL=BAAI/bge-reranker-v2-m3
RERANKER_DEVICE=cuda
RETRIEVAL_TOP_K=20              # lấy 20 chunks từ hybrid search
RERANK_TOP_N=5                  # giữ lại 5 sau rerank để đưa vào LLM
RETRIEVAL_SCORE_THRESHOLD=0.6  # score thấp hơn → trigger CRAG fallback

API_HOST=0.0.0.0
API_PORT=8081
API_DEBUG=true

